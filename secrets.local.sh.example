# Copy to secrets.local.sh — do not commit.
#
# Only one key needed (service.xxx from panel → سرویس‌ها):
export NESHAN_API_KEY="service.your_neshan_service_key_here"
#
# Android map: download neshan.license (panel → ANDROID → دریافت لایسنس)
# Place via: ./scripts/sync_neshan_license.sh
#
# Panel checklist:
# - ANDROID: package com.example.uzita + SHA-1 (./scripts/print_android_sha1.sh)
# - سرویس‌ها: enable Geocoding Plus + Routing with traffic
# - Service key domains: device-control.liara.run, ellaro.liara.run (NOT package name)
#
# Optional separate Android REST key (usually NOT shown in panel — license is enough for map):
# export NESHAN_ANDROID_KEY=""
#
# Build:
#   ./scripts/build_apk.sh
